{%- if cookiecutter.enable_docker %}
# {{ cookiecutter.project_name }} - Production Environment
# Generated by fastapi-fullstack v{{ cookiecutter.generator_version }}
#
# IMPORTANT: Copy this file to .env.prod before deploying
#   cp .env.prod.example .env.prod
#
# WARNING: Never commit .env.prod to version control!

# === Container Prefix (must be unique per server) ===
CONTAINER_PREFIX={{ cookiecutter.project_slug }}

{%- if cookiecutter.include_traefik_labels %}

# === Domain Configuration ===
DOMAIN=example.com
ACME_EMAIL=admin@example.com
{%- endif %}

{%- if cookiecutter.use_nginx %}

# === Domain Configuration ===
DOMAIN=example.com
# Note: Place SSL certificates in nginx/ssl/ directory:
#   - nginx/ssl/cert.pem (certificate chain)
#   - nginx/ssl/key.pem (private key)
{%- endif %}

{%- if cookiecutter.use_postgresql %}

# === PostgreSQL ===
POSTGRES_USER=postgres
POSTGRES_PASSWORD=  # Generate: openssl rand -base64 32
POSTGRES_DB={{ cookiecutter.project_slug }}
{%- endif %}

{%- if cookiecutter.enable_redis %}

# === Redis ===
REDIS_PASSWORD=  # Generate: openssl rand -base64 32
{%- endif %}

{%- if cookiecutter.use_milvus %}

# === Milvus (RAG Vector Database) ===
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_DATABASE=default

{%- if cookiecutter.use_openai_embeddings %}
# OpenAI Embeddings API Key
OPENAI_API_KEY=
{%- endif %}

{%- if cookiecutter.use_voyage_embeddings %}
# Voyage AI Embeddings API Key
VOYAGE_API_KEY=
{%- endif %}

{%- if cookiecutter.enable_reranker %}
# Cohere Reranker API Key
COHERE_API_KEY=
{%- endif %}

{%- if cookiecutter.pdf_parser == "llamaparse" %}
# LlamaParse API Key
LLAMAPARSE_API_KEY=
{%- endif %}

{%- if cookiecutter.enable_google_drive_ingestion %}
# Google Drive service account JSON key file
GOOGLE_DRIVE_CREDENTIALS_FILE=credentials/google-drive-sa.json
{%- endif %}
{%- endif %}

{%- if cookiecutter.use_jwt %}

# === JWT Secret ===
SECRET_KEY=  # Generate: openssl rand -hex 32
{%- endif %}

{%- if cookiecutter.include_traefik_service %}

# === Traefik Dashboard ===
# Generate with: htpasswd -nb admin yourpassword
# Example: admin:$apr1$xyz$hash
TRAEFIK_DASHBOARD_AUTH=
{%- endif %}

{%- if cookiecutter.use_celery %}

# === Flower Monitoring ===
FLOWER_USER=admin
FLOWER_PASSWORD=  # Generate: openssl rand -base64 16
{%- endif %}

{%- if cookiecutter.use_telegram or cookiecutter.use_slack %}

# === Messaging Channels ===
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CHANNEL_ENCRYPTION_KEY=
{%- if cookiecutter.use_telegram %}
TELEGRAM_WEBHOOK_BASE_URL=https://api.example.com
{%- endif %}
{%- if cookiecutter.use_slack %}
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
{%- endif %}
{%- endif %}
{%- else %}
# Docker is disabled for this project
{%- endif %}
