# {{ cookiecutter.project_name }} Environment Variables

# === Project ===
PROJECT_NAME={{ cookiecutter.project_name }}
DEBUG=true
ENVIRONMENT=local
TIMEZONE={{ cookiecutter.timezone }}  # IANA timezone: UTC, Europe/Warsaw, America/New_York
MODELS_CACHE_DIR=./models_cache

{%- if cookiecutter.enable_logfire %}

# === Logfire ===
# Get your token at https://logfire.pydantic.dev
LOGFIRE_TOKEN=
LOGFIRE_SERVICE_NAME={{ cookiecutter.project_slug }}
LOGFIRE_ENVIRONMENT=development
{%- endif %}

{%- if cookiecutter.use_postgresql %}

# === PostgreSQL ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB={{ cookiecutter.project_slug }}
{%- endif %}

{%- if cookiecutter.use_mongodb %}

# === MongoDB ===
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB={{ cookiecutter.project_slug }}
# MONGO_USER=
# MONGO_PASSWORD=
{%- endif %}

{%- if cookiecutter.use_sqlite %}

# === SQLite ===
SQLITE_PATH=./data/{{ cookiecutter.project_slug }}.db
{%- endif %}

{%- if cookiecutter.use_jwt %}

# === JWT Auth ===
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ALGORITHM=HS256
{%- endif %}

{%- if cookiecutter.use_api_key %}

# === API Key Auth ===
API_KEY=change-me-in-production
API_KEY_HEADER=X-API-Key
{%- endif %}

{%- if cookiecutter.enable_redis %}

# === Redis ===
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=
REDIS_DB=0
{%- endif %}

{%- if cookiecutter.enable_rag %}

# === RAG Configuration ===
RAG_DEFAULT_COLLECTION=documents
RAG_TOP_K=10
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
RAG_CHUNKING_STRATEGY=recursive  # recursive, markdown, or fixed
RAG_HYBRID_SEARCH=false  # Enable BM25 + vector hybrid search
RAG_ENABLE_OCR=false  # OCR fallback for scanned PDFs (requires tesseract-ocr installed)

{%- if cookiecutter.use_milvus %}
# Vector Database (Milvus)
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_DATABASE=default
MILVUS_TOKEN=root:Milvus
{%- endif %}
{%- if cookiecutter.use_qdrant %}
# Vector Database (Qdrant)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
{%- endif %}
{%- if cookiecutter.use_chromadb %}
# Vector Database (ChromaDB)
# Leave CHROMA_HOST empty for embedded/persistent mode
CHROMA_HOST=
CHROMA_PORT=8100
CHROMA_PERSIST_DIR=./chroma_data
{%- endif %}
{%- if cookiecutter.use_pgvector %}
# Vector Database (pgvector) — uses existing PostgreSQL connection
{%- endif %}

{%- if cookiecutter.enable_reranker and cookiecutter.use_cross_encoder_reranker %}
# Reranker
HF_TOKEN=
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L6-v2
{%- endif %}

{%- if cookiecutter.use_all_pdf_parsers %}
# === PDF Parser Selection ===
# RAG ingestion parser: pymupdf, llamaparse, liteparse
PDF_PARSER=pymupdf
# Chat file attachment parser: pymupdf, llamaparse, liteparse
CHAT_PDF_PARSER=pymupdf
LLAMAPARSE_API_KEY=
LLAMAPARSE_TIER=agentic  # fast, cost_effective, agentic, agentic_plus
{%- elif cookiecutter.use_llamaparse %}
# LlamaParse (AI-powered document parsing)
LLAMAPARSE_API_KEY=
LLAMAPARSE_TIER=agentic  # fast, cost_effective, agentic, agentic_plus
{%- endif %}

{%- if cookiecutter.enable_rag_image_description %}
# Image Description (LLM vision)
RAG_IMAGE_DESCRIPTION_MODEL=  # empty = use AI_MODEL
{%- endif %}

{%- if cookiecutter.enable_google_drive_ingestion %}
# Google Drive (service account)
GOOGLE_DRIVE_CREDENTIALS_FILE=credentials/google-drive-sa.json
{%- endif %}

{%- if cookiecutter.enable_s3_ingestion %}
# S3/MinIO (document ingestion)
S3_RAG_ENDPOINT=
S3_RAG_ACCESS_KEY=
S3_RAG_SECRET_KEY=
S3_RAG_BUCKET={{ cookiecutter.project_slug }}-rag
S3_RAG_REGION=us-east-1
{%- endif %}

{%- endif %}

{%- if cookiecutter.use_celery %}

# === Celery ===
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
{%- endif %}

{%- if cookiecutter.use_taskiq %}

# === Taskiq ===
TASKIQ_BROKER_URL=redis://localhost:6379/1
TASKIQ_RESULT_BACKEND=redis://localhost:6379/1
{%- endif %}

{%- if cookiecutter.use_arq %}

# === ARQ (Async Redis Queue) ===
ARQ_REDIS_HOST=localhost
ARQ_REDIS_PORT=6379
# ARQ_REDIS_PASSWORD=
ARQ_REDIS_DB=2
{%- endif %}

{%- if cookiecutter.enable_sentry %}

# === Sentry ===
SENTRY_DSN=
{%- endif %}

{%- if cookiecutter.enable_prometheus %}

# === Prometheus ===
PROMETHEUS_METRICS_PATH=/metrics
PROMETHEUS_INCLUDE_IN_SCHEMA=false
{%- endif %}

{%- if cookiecutter.enable_file_storage %}

# === S3/MinIO Storage ===
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET={{ cookiecutter.project_slug }}
S3_REGION=us-east-1
{%- endif %}


# === AI Agent ({{ cookiecutter.ai_framework }}, {{ cookiecutter.llm_provider }}) ===
{%- if cookiecutter.use_openai %}
OPENAI_API_KEY=
AI_MODEL=gpt-4.1-mini
{%- endif %}
{%- if cookiecutter.use_anthropic %}
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-6
{%- endif %}
{%- if cookiecutter.use_google %}
GOOGLE_API_KEY=
AI_MODEL=gemini-2.5-flash
{%- endif %}
{%- if cookiecutter.use_openrouter %}
OPENROUTER_API_KEY=
AI_MODEL=anthropic/claude-sonnet-4-6
{%- endif %}
AI_TEMPERATURE=0.7
{%- if cookiecutter.enable_web_search %}

# === Web Search (Tavily) ===
# Get your API key at https://tavily.com
TAVILY_API_KEY=
{%- endif %}
{%- if cookiecutter.enable_langsmith %}

# === LangSmith Observability ===
# Get your API key at https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT={{ cookiecutter.project_slug }}
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
{%- endif %}
{%- if cookiecutter.use_deepagents %}

# === DeepAgents Configuration ===
# Backend type: "state" (in-memory, default)
DEEPAGENTS_BACKEND_TYPE=state
# Memory file paths (comma-separated AGENTS.md paths, e.g. "/memory/AGENTS.md")
DEEPAGENTS_MEMORY_PATHS=
# Skills paths (comma-separated, relative paths e.g. "/skills/user/,/skills/project/")
DEEPAGENTS_SKILLS_PATHS=
# Enable/disable built-in tools
DEEPAGENTS_ENABLE_FILESYSTEM=true
DEEPAGENTS_ENABLE_EXECUTE=false
DEEPAGENTS_ENABLE_TODOS=true
DEEPAGENTS_ENABLE_SUBAGENTS=true
# Human-in-the-loop: tools requiring approval (comma-separated, or "all")
# e.g. "write_file,edit_file,execute" or leave empty to disable HITL
DEEPAGENTS_INTERRUPT_TOOLS=
# Allowed decisions for interrupted tools (approve, edit, reject)
DEEPAGENTS_ALLOWED_DECISIONS=approve,edit,reject
{%- endif %}

{%- if cookiecutter.enable_rag %}
# Embeddings
{%- if cookiecutter.use_openai_embeddings %}
# OpenAI Embeddings
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
{%- elif cookiecutter.use_voyage_embeddings %}
# Voyage AI Embeddings
VOYAGE_API_KEY=
EMBEDDING_MODEL=voyage-3
{%- elif cookiecutter.use_sentence_transformers %}
# Sentence Transformers (local, no API key needed)
EMBEDDING_MODEL=all-MiniLM-L6-v2
{%- else %}
# Default OpenAI Embeddings
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
{%- endif %}

# Chunking
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50

# Retrieval
RAG_DEFAULT_COLLECTION=documents
RAG_TOP_K=10

# Reranker
{%- if cookiecutter.use_cohere_reranker %}
COHERE_API_KEY=
{%- endif %}

# PDF Parser
{%- if cookiecutter.use_all_pdf_parsers %}
PDF_PARSER=pymupdf
CHAT_PDF_PARSER=pymupdf
LLAMAPARSE_API_KEY=
{%- elif cookiecutter.use_llamaparse %}
LLAMAPARSE_API_KEY=
{%- endif %}

# Google Drive (optional, for document ingestion)
{%- if cookiecutter.enable_google_drive_ingestion %}
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=
{%- endif %}

{%- endif %}

{%- if cookiecutter.use_telegram or cookiecutter.use_slack %}

# === Messaging Channels ===
# Fernet encryption key for bot token storage — generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CHANNEL_ENCRYPTION_KEY=
{%- if cookiecutter.use_telegram %}
# Telegram: webhook base URL for production (e.g. https://api.yourdomain.com)
# Leave empty to use long-polling mode (recommended for development)
TELEGRAM_WEBHOOK_BASE_URL=
{%- endif %}
{%- if cookiecutter.use_slack %}
# Slack app credentials — from https://api.slack.com/apps
# Signing secret: Basic Information → App Credentials → Signing Secret
SLACK_SIGNING_SECRET=
# Bot token: OAuth & Permissions → Bot User OAuth Token (xoxb-...)
SLACK_BOT_TOKEN=
# App-level token: Basic Information → App-Level Tokens (xapp-..., for Socket Mode dev)
SLACK_APP_TOKEN=
{%- endif %}
{%- endif %}

{%- if cookiecutter.enable_cors %}

# === CORS ===
# JSON list of allowed origins (default: localhost:3000, localhost:8080)
# Note: "*" is blocked in production - specify explicit origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
{%- endif %}

{%- if cookiecutter.enable_docker %}

# === Docker Production (Traefik) ===
# Domain for production deployment
DOMAIN=example.com

# Let's Encrypt email for SSL certificates
ACME_EMAIL=admin@example.com

# Traefik dashboard auth (generate with: htpasswd -nb admin password)
# TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$...

{%- if cookiecutter.enable_redis %}
# Redis password for production
REDIS_PASSWORD=change-me-in-production
{%- endif %}

{%- if cookiecutter.use_celery %}
# Flower monitoring credentials
FLOWER_USER=admin
FLOWER_PASSWORD=change-me-in-production
{%- endif %}
{%- endif %}
