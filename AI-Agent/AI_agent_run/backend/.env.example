# AI_agent_run Environment Variables

# === Project ===
PROJECT_NAME=AI_agent_run
DEBUG=true
ENVIRONMENT=local
TIMEZONE=UTC  # IANA timezone: UTC, Europe/Warsaw, America/New_York
MODELS_CACHE_DIR=./models_cache

# === SQLite ===
SQLITE_PATH=./data/AI_agent_run.db

# === JWT Auth ===
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ALGORITHM=HS256

# === API Key Auth ===
API_KEY=change-me-in-production
API_KEY_HEADER=X-API-Key


# === AI Agent (pydantic_ai, google/gemini) ===
LLM_PROVIDER=google
GEMINI_API_KEY=
OPENAI_API_KEY=
AI_MODEL=gemini-2.0-flash-lite
AI_TEMPERATURE=0.7

# === Sales Management Mini analytics datasource ===
SALES_DB_ENABLED=true
SALES_DB_HOST=100.65.39.120
SALES_DB_PORT=3306
SALES_DB_NAME=sales_management_mini
SALES_DB_USER=root
SALES_DB_PASSWORD=12345
SALES_BACKEND_BASE_URL=http://localhost:8080

# === CORS ===
# JSON list of allowed origins (default: localhost:3000, localhost:8080)
# Note: "*" is blocked in production - specify explicit origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:8080","http://localhost:8088"]
