{
  "info": {
    "name": "Quản lý bán hàng API",
    "description": "1) Gọi **00 - Auth → POST login** (username/password trong biến `loginUsername` / `loginPassword`). Script tự ghi `accessToken` vào biến collection.\n2) Các request còn lại dùng **Authorization: Bearer {{accessToken}}** (kế thừa từ collection).\n3) Chỉ **GET /health** và **POST /auth/login** không cần token.\n4) Chỉnh `baseUrl`, `storeId`, `variantId`, `orderId`, `orderItemId`, … theo DB thật.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api" },
    { "key": "accessToken", "value": "" },
    { "key": "loginUsername", "value": "admin" },
    { "key": "loginPassword", "value": "your-password" },
    { "key": "storeId", "value": "1" },
    { "key": "toStoreId", "value": "2" },
    { "key": "variantId", "value": "1" },
    { "key": "supplierId", "value": "1" },
    { "key": "customerId", "value": "1" },
    { "key": "orderId", "value": "1" },
    { "key": "orderItemId", "value": "1" },
    { "key": "receiptId", "value": "1" },
    { "key": "returnId", "value": "1" },
    { "key": "transferId", "value": "1" },
    { "key": "stocktakeId", "value": "1" }
  ],
  "item": [
    {
      "name": "00 - Auth",
      "item": [
        {
          "name": "POST login (lưu token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var j = pm.response.json();",
                  "  if (j.accessToken) pm.collectionVariables.set('accessToken', j.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{loginUsername}}\",\n  \"password\": \"{{loginPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/login",
            "description": "Trả về `accessToken`, `tokenType`, `expiresInSeconds`, `userId`, `username`, `roles`. Token được lưu vào biến collection `accessToken`."
          }
        }
      ]
    },
    {
      "name": "01 - Health",
      "item": [
        {
          "name": "GET health",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
